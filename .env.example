# Database — pooler for runtime, direct for migrations
DATABASE_URL=postgresql://url&channel_binding=require
DIRECT_URL=postgresql://url

# Application Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,https://khazana-pos-frontend-rose.vercel.app
FRONTEND_URL=https://khazana-pos-frontend-rose.vercel.app

# JWT Configuration
JWT_SECRET=jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=encryption_key_change_this_in_production

# API Configuration
API_PREFIX=api
API_VERSION=v1


# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=cloud_name_here
CLOUDINARY_API_KEY=api_key_here
CLOUDINARY_API_SECRET=api_secret_here
CLOUDINARY_FOLDER=khazana_pos

#mail configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email_user_here
SMTP_PASS=email_password_here
FROM_EMAIL=email_from_here
FROM_NAME=Khazana Mithai Team