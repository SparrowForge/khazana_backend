// ==================== PACKET MANAGEMENT ====================

model PacketInfo {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  code       String           @unique @map("Code")
  name       String?          @map("Name")
  uom        String?          @map("UOM")
  weight     Decimal?         @map("Weight") @db.Decimal(18, 2)
  rate       Decimal?         @map("Rate") @db.Decimal(18, 2)
  remarks    String?          @map("Remarks")
  isActive   Int?             @map("IsActive")
  createBy   String?          @map("CreateBy")
  createDate DateTime?        @map("CreateDate")
  updateBy   String?          @map("UpdateBy")
  updateDate DateTime?        @map("UpdateDate")
  receives   Packet_Receive[]
  issues     Packet_Issue[]

  @@map("PacketInfo")
}

model Packet_Receive {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  serialNo    String?     @map("SerialNo")
  voucharNo   String?     @map("VoucharNo")
  code        String?     @map("Code")
  qty         Decimal?    @map("Qty") @db.Decimal(18, 2)
  receiveDate DateTime?   @map("ReceiveDate")
  isActive    Int?        @map("IsActive")
  createBy    String?     @map("CreateBy")
  createDate  DateTime?   @map("CreateDate")
  branchId    Int         @map("BranchId")
  packet      PacketInfo? @relation(fields: [code], references: [code])

  @@map("Packet_Receive")
}

model Packet_Issue {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  serialNo   String?     @map("SerialNo")
  invoiceNo  String?     @map("InvoiceNo")
  issueType  String?     @map("IssueType")
  code       String?     @map("Code")
  qty        Decimal?    @map("Qty") @db.Decimal(18, 2)
  issueDate  DateTime?   @map("IssueDate")
  isActive   Int?        @map("IsActive")
  updateDate DateTime?   @map("UpdateDate")
  createBy   String?     @map("CreateBy")
  createDate DateTime?   @map("CreateDate")
  updateBy   String?     @map("UpdateBy")
  branchId   Int         @map("BranchId")
  packet     PacketInfo? @relation(fields: [code], references: [code])

  @@map("Packet_Issue")
}

