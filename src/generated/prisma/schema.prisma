generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== BRANCH & SYSTEM ====================

model Branch {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @map("Id") @db.Uuid
  branchCode String? @unique @map("BranchCode")
  branchName String? @map("BranchName")
  address    String? @map("Address")
  vatNo      String? @map("VatNo")
  mobileNo   String? @map("MobileNo")
  users      User[]

  @@map("Branch")
}

model Bank {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  name       String?    @map("Name")
  createBy   String?    @map("CreateBy")
  createDate DateTime?  @map("CreateDate")
  sales      t_SOMstr[]

  @@map("Bank")
}

model Setup_System {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  companyName    String  @map("CompanyName")
  companyAddress String? @map("CompanyAddress")
  companyUtility String? @map("CompanyUtility")
  reportFooter   String? @map("ReportFooter")

  @@map("Setup_System")
}

// ==================== AUTHENTICATION & USERS ====================

model User {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  name           String?      @map("Name")
  userName       String       @unique @map("UserName")
  password       String?      @map("Password")
  branchId       String       @map("BranchId") @db.Uuid
  validUntil     DateTime?    @map("ValidUntil")
  isActive       String?      @map("IsActive")
  creator        String?      @map("Creator")
  creationDate   DateTime?    @map("CreationDate")
  lastUpdateBy   String?      @map("LastUpdateBy")
  lastUpdateDate DateTime?    @map("LastUpdateDate")
  isDeleted      String?      @map("IsDeleted")
  deletedBy      String?      @map("DeletedBy")
  deletionDate   DateTime?    @map("DeletionDate")
  remarks        String?      @map("Remarks")
  branch         Branch       @relation(fields: [branchId], references: [id])
  userRoles      t_UserRole[]

  @@map("t_User")
}

model t_UserRole {
  userId       String  @map("UserID")
  controlName  String  @map("ControlName")
  isEnable     String? @map("IsEnable")
  addAccess    String? @map("AddAccess")
  editAccess   String? @map("EditAccess")
  deleteAccess String? @map("DeleteAccess")
  user         User    @relation(fields: [userId], references: [userName])

  @@id([userId, controlName])
  @@map("t_UserRole")
}

model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  actionPage String?   @map("ActionPage")
  actionDone String?   @map("ActionDone")
  userName   String?   @map("UserName")
  date       DateTime? @map("Date")
  module     String?   @map("Module")
  ipAddress  String?   @map("IpAddress")
  userAgent  String?   @map("UserAgent")

  @@map("AuditLog")
}

model AuditLogs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model Menu {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  menuName    String       @map("MenuName")
  controlName String       @unique @map("ControlName")
  description String?      @map("Description")
  icon        String?      @map("Icon")
  order       Int?         @map("Order")
  parentMenu  String?      @map("ParentMenu")
  isActive    Boolean?     @map("IsActive")
  permissions Permission[]

  @@map("Menu")
}

model Role {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  name        String       @unique @map("Name")
  description String?      @map("Description")
  permissions Permission[]

  @@map("Role")
}

model Permission {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  roleId    String  @map("RoleId") @db.Uuid
  menuId    String  @map("MenuId") @db.Uuid
  isEnable  Boolean @default(false) @map("IsEnable")
  canCreate Boolean @default(false) @map("CanCreate")
  canEdit   Boolean @default(false) @map("CanEdit")
  canDelete Boolean @default(false) @map("CanDelete")
  role      Role    @relation(fields: [roleId], references: [id])
  menu      Menu    @relation(fields: [menuId], references: [id])

  @@unique([roleId, menuId])
  @@map("Permission")
}

// ==================== CUSTOMERS ====================

model Customer {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  code               String               @unique @map("Code")
  name               String               @map("Name")
  mobile             String?              @map("Mobile")
  address            String?              @map("Address")
  email              String?              @map("EMail")
  joiningDate        DateTime?            @map("JoiningDate")
  sales              CSMaster[]
  salesVat           CSVMaster[]
  clientTransactions Client_Transaction[]
  moneyReceives      MoneyReceive[]

  @@map("Customer")
}

model Client_Transaction {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  clientCode    String?   @map("ClientCode")
  paymentDate   DateTime? @map("PaymentDate")
  paymentAmount Decimal?  @map("PaymentAmount") @db.Decimal(9, 2)
  tType         String?   @map("TType")
  serialNo      String?   @map("SerialNo")
  moneyReceptNo String?   @map("MoneyReceptNo")
  bankName      String?   @map("BankName")
  bankNo        String?   @map("BankNo")
  customer      Customer? @relation(fields: [clientCode], references: [code])

  @@map("Client_Transaction")
}

// ==================== EMPLOYEES ====================

model Employee {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  code        String    @unique @map("Code")
  name        String?   @map("Name")
  mobile      String?   @map("Mobile")
  address     String?   @map("Address")
  email       String?   @map("Email")
  nationalId  String?   @map("NationalID")
  education   String?   @map("Education")
  dateOfBirth DateTime? @map("DateOfBirth")
  joiningDate DateTime? @map("JoiningDate")

  @@map("Employee")
}

// ==================== ITEMS ====================

model Item_Information {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  itmCode               String         @unique @map("itmCode")
  itmName               String?        @map("itmName")
  itmCategory           String?        @map("itmCategory")
  itmType               String?        @map("itmType")
  itmUOM                String?        @map("itmUOM")
  itmRemarks            String?        @map("itmRemarks")
  itmOrderLevel         Decimal?       @map("itmOrderLevel") @db.Decimal(9, 2)
  orderLevelUOM         String?        @map("OrderLevelUOM")
  isActive              String?        @map("IsActive")
  // Relations using Item_Information.ID (uuid)
  runningSaleDetails    t_SODet[]
  runningSaleVatDetails t_SODeV[]
  ncDetails             t_NCDet[]
  asstDetails           AsstDet[]
  itemRejects           ItemReject[]
  // Relations using Item_Information.itmCode (varchar)
  itemReceives          Item_Receive[]
  itemIssues            Item_Issue[]
  inventory             Inventory?
  prices                t_Price[]      @relation("ItemPrices")
  costPrices            t_CostPr[]     @relation("ItemCostPrices")

  @@map("Item_Information")
}

model Item_Category {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  code    String  @unique @map("Code")
  name    String? @map("Name")
  remarks String? @map("Remarks")

  @@map("Item_Category")
}

model RW_Stock {
  itemCode  String  @id @map("ItemCode")
  stockQty  Decimal @map("StockQty") @db.Decimal(9, 2)
  unitPrice Decimal @map("UnitPrice") @db.Decimal(9, 4)
  branchId  Int?    @map("BranchId")

  @@map("RW_Stock")
}

model Inventory {
  itemCode String           @id @map("ItemCode")
  quantity Decimal          @default(0) @map("Quantity") @db.Decimal(18, 4)
  item     Item_Information @relation(fields: [itemCode], references: [itmCode])

  @@map("Inventory")
}

// ==================== PRICING ====================

model t_Price {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @map("Price_OId") @db.Uuid
  priceItemOId      String            @map("Price_ItemOId")
  priceFromDate     DateTime?         @map("Price_FromDate")
  priceToDate       DateTime?         @map("Price_ToDate")
  priceListPrice    Float?            @map("Price_ListPrice")
  priceVatPercent   Float?            @map("Price_VatPercent")
  priceVatPrice     Float?            @map("Price_VatPrice")
  priceDiscPrice    Float?            @map("Price_DiscPrice")
  priceCreator      String?           @map("Price_Creator")
  priceCreationDate DateTime?         @map("Price_CreationDate")
  priceUpdateBy     String?           @map("Price_UpdateBy")
  priceUpdateDate   DateTime?         @map("Price_UpdateDate")
  priceIsActive     Int?              @map("Price_IsActive")
  item              Item_Information? @relation("ItemPrices", fields: [priceItemOId], references: [itmCode])

  @@map("t_Price")
}

model t_CostPr {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @map("Price_OId") @db.Uuid
  priceItemOId      String            @map("Price_ItemOId")
  priceFromDate     DateTime?         @map("Price_FromDate")
  priceToDate       DateTime?         @map("Price_ToDate")
  priceListPrice    Float?            @map("Price_ListPrice")
  priceVatPercent   Float?            @map("Price_VatPercent")
  priceVatPrice     Float?            @map("Price_VatPrice")
  priceDiscPrice    Float?            @map("Price_DiscPrice")
  priceCreator      String?           @map("Price_Creator")
  priceCreationDate DateTime?         @map("Price_CreationDate")
  priceUpdateBy     String?           @map("Price_UpdateBy")
  priceUpdateDate   DateTime?         @map("Price_UpdateDate")
  priceIsActive     Int?              @map("Price_IsActive")
  item              Item_Information? @relation("ItemCostPrices", fields: [priceItemOId], references: [itmCode])

  @@map("t_CostPr")
}

// ==================== CREDIT SALES (NON-VAT) ====================

model CSMaster {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  invNo           String     @unique @map("InvNo")
  invDate         DateTime?  @map("InvDate")
  poNo            String?    @map("PONo")
  invoiceBy       String?    @map("InvoiceBy")
  manualInvoice   String?    @map("ManualInvoice")
  clientCode      String?    @map("ClientCode")
  totalAmount     Decimal?   @map("TotalAmount") @db.Decimal(9, 2)
  totalDiscount   Decimal?   @map("TotalDiscount") @db.Decimal(8, 2)
  totalVat        Decimal?   @map("TotalVat") @db.Decimal(8, 2)
  discountRemarks String?    @map("DiscountRemarks")
  isActive        Int?       @map("IsActive")
  branchId        Int?       @map("BranchId")
  createDate      DateTime?  @map("CreateDate")
  customer        Customer?  @relation(fields: [clientCode], references: [code])
  details         CSDetail[]

  @@map("CSMaster")
}

model CSDetail {
  id      String    @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  invNo   String?   @map("InvNo")
  itemOId String?   @map("ItemOId")
  rate    Decimal?  @map("Rate") @db.Decimal(8, 2)
  qty     Decimal?  @map("Qty") @db.Decimal(8, 2)
  value   Decimal?  @map("Value") @db.Decimal(8, 2)
  disc    Decimal?  @map("Disc") @db.Decimal(8, 2)
  vat     Decimal?  @map("vat") @db.Decimal(8, 2)
  total   Decimal?  @map("total") @db.Decimal(18, 2)
  sale    CSMaster? @relation(fields: [invNo], references: [invNo])

  @@map("CSDetail")
}

// ==================== CREDIT SALES (VAT) ====================

model CSVMaster {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  invNo           String      @unique @map("InvNo")
  invDate         DateTime?   @map("InvDate")
  poNo            String?     @map("PONo")
  invoiceBy       String?     @map("InvoiceBy")
  manualInvoice   String?     @map("ManualInvoice")
  clientCode      String?     @map("ClientCode")
  totalAmount     Decimal?    @map("TotalAmount") @db.Decimal(18, 6)
  totalDiscount   Decimal?    @map("TotalDiscount") @db.Decimal(18, 6)
  totalVat        Decimal?    @map("TotalVat") @db.Decimal(18, 6)
  discountRemarks String?     @map("DiscountRemarks")
  branchId        Int?        @map("BranchId")
  customer        Customer?   @relation(fields: [clientCode], references: [code])
  details         CSVDetail[]

  @@map("CSVMaster")
}

model CSVDetail {
  id      String     @id @default(dbgenerated("gen_random_uuid()")) @map("ID") @db.Uuid
  invNo   String?    @map("InvNo")
  itemOId String?    @map("ItemOId")
  rate    Decimal?   @map("Rate") @db.Decimal(18, 6)
  qty     Decimal?   @map("Qty") @db.Decimal(18, 6)
  value   Decimal?   @map("Value") @db.Decimal(18, 6)
  disc    Decimal?   @map("Disc") @db.Decimal(18, 6)
  vat     Decimal?   @map("vat") @db.Decimal(18, 6)
  total   Decimal?   @map("total") @db.Decimal(18, 6)
  sale    CSVMaster? @relation(fields: [invNo], references: [invNo])

  @@map("CSVDetail")
}

// ==================== RUNNING SALES (CASH / NON-VAT) ====================

model t_SOMstr {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @map("SOMstr_OID") @db.Uuid
  somstrCode            String?   @map("SOMstr_Code")
  somstrDate            DateTime? @map("SOMstr_Date")
  somstrTotalAmt        Decimal?  @map("SOMstr_TotalAmt") @db.Decimal(18, 4)
  somstrDiscAmt         Decimal?  @map("SOMstr_DiscAmt") @db.Decimal(18, 4)
  somstrNetAmt          Decimal?  @map("SOMstr_NetAmt") @db.Decimal(18, 4)
  somstrVatClnNo        String?   @map("SOMstr_VatClnNo")
  somstrVatDate         DateTime? @map("SOMstr_VatDate")
  somstrPricingDate     DateTime? @map("SOMstr_PricingDate")
  somstrCreator         String?   @map("SOMstr_Creator")
  somstrCreationDate    DateTime? @map("SOMstr_CreationDate")
  somstrUpdateBy        String?   @map("SOMstr_UpdateBy")
  somstrUpdateDate      DateTime? @map("SOMstr_UpdateDate")
  somstrIsActive        Boolean?  @map("SOMstr_IsActive")
  somstrCustomerpay     Decimal?  @map("SOMstr_Customerpay") @db.Decimal(18, 4)
  somstrChange          Decimal?  @map("SOMstr_Change") @db.Decimal(18, 4)
  branchId              Int?      @map("BranchId")
  soMstrDiscountRemarks String?   @map("SoMstr_DiscountRemarks")
  soMstrModifyRemarks   String?   @map("SoMstr_ModifyRemarks")
  soMstrDiscountContact String?   @map("SoMstr_DiscountContact")
  mtype                 String?   @map("Mtype")
  soMstrMBank           String?   @map("SoMstr_MBank") @db.Uuid
  bank                  Bank?     @relation(fields: [soMstrMBank], references: [id])
  details               t_SODet[]

  @@map("t_SOMstr")
}

model t_SODet {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @map("SODet_OID") @db.Uuid
  t_SOMstr_id    String?           @map("SODet_MStrOID") @db.Uuid
  sodetItemSLNum String?           @map("SODet_ItemSLNum")
  sodetItemOID   String            @map("SODet_ItemOID") @db.Uuid
  sodetQTY       Decimal?          @map("SODet_QTY") @db.Decimal(18, 4)
  sodetUOM       String?           @map("SODet_UOM")
  sodetPrice     Decimal?          @map("SODet_Price") @db.Decimal(18, 4)
  sodetAmount    Decimal?          @map("SODet_Amount") @db.Decimal(18, 4)
  sodetSDValue   Decimal?          @map("SODet_SDValue") @db.Decimal(18, 4)
  sodetSDAmount  Decimal?          @map("SODet_SDAmount") @db.Decimal(18, 4)
  sodetVATValue  Decimal?          @map("SODet_VATValue") @db.Decimal(18, 4)
  sodetVATAmount Decimal?          @map("SODet_VATAmount") @db.Decimal(18, 4)
  sodetDiscount  Decimal?          @map("SODet_Discount") @db.Decimal(18, 4)
  sodetNetAmount Decimal?          @map("SODet_NetAmount") @db.Decimal(18, 4)
  branchId       Int?              @map("BranchId")
  sale           t_SOMstr?         @relation(fields: [t_SOMstr_id], references: [id])
  item           Item_Information? @relation(fields: [sodetItemOID], references: [id])

  @@map("t_SODet")
}

// ==================== RUNNING SALES (VAT) ====================

model t_SOMstV {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @map("SOMstr_OID") @db.Uuid
  somstrCode            String?   @map("SOMstr_Code")
  somstrDate            DateTime? @map("SOMstr_Date")
  somstrTotalAmt        Decimal?  @map("SOMstr_TotalAmt") @db.Decimal(18, 6)
  somstrDiscAmt         Decimal?  @map("SOMstr_DiscAmt") @db.Decimal(18, 6)
  somstrNetAmt          Decimal?  @map("SOMstr_NetAmt") @db.Decimal(18, 6)
  somstrVatClnNo        String?   @map("SOMstr_VatClnNo")
  somstrVatDate         DateTime? @map("SOMstr_VatDate")
  somstrPricingDate     DateTime? @map("SOMstr_PricingDate")
  somstrCreator         String?   @map("SOMstr_Creator")
  somstrCreationDate    DateTime? @map("SOMstr_CreationDate")
  somstrUpdateBy        String?   @map("SOMstr_UpdateBy")
  somstrUpdateDate      DateTime? @map("SOMstr_UpdateDate")
  somstrIsActive        Boolean?  @map("SOMstr_IsActive")
  somstrCustomerpay     Decimal?  @map("SOMstr_Customerpay") @db.Decimal(18, 4)
  somstrChange          Decimal?  @map("SOMstr_Change") @db.Decimal(18, 4)
  branchId              Int?      @map("BranchId")
  soMstrDiscountRemarks String?   @map("SoMstr_DiscountRemarks")
  soMstrModifyRemarks   String?   @map("SoMstr_ModifyRemarks")
  soMstrDiscountContact String?   @map("SoMstr_DiscountContact")
  mtype                 String?   @map("Mtype")
  details               t_SODeV[]

  @@map("t_SOMstV")
}

model t_SODeV {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @map("SODet_OID") @db.Uuid
  t_SOMstV_id    String?           @map("SODet_MStrOID") @db.Uuid
  sodetItemSLNum String?           @map("SODet_ItemSLNum")
  sodetItemOID   String            @map("SODet_ItemOID") @db.Uuid
  sodetQTY       Decimal?          @map("SODet_QTY") @db.Decimal(18, 6)
  sodetUOM       String?           @map("SODet_UOM")
  sodetPrice     Decimal?          @map("SODet_Price") @db.Decimal(18, 6)
  sodetAmount    Decimal?          @map("SODet_Amount") @db.Decimal(18, 6)
  sodetSDValue   Decimal?          @map("SODet_SDValue") @db.Decimal(18, 6)
  sodetSDAmount  Decimal?          @map("SODet_SDAmount") @db.Decimal(18, 6)
  sodetVATValue  Decimal?          @map("SODet_VATValue") @db.Decimal(18, 6)
  sodetVATAmount Decimal?          @map("SODet_VATAmount") @db.Decimal(18, 6)
  sodetDiscount  Decimal?          @map("SODet_Discount") @db.Decimal(18, 6)
  sodetNetAmount Decimal?          @map("SODet_NetAmount") @db.Decimal(18, 6)
  branchId       Int?              @map("BranchId")
  sale           t_SOMstV?         @relation(fields: [t_SOMstV_id], references: [id])
  item           Item_Information? @relation(fields: [sodetItemOID], references: [id])

  @@map("t_SODeV")
}

// ==================== ASSORTMENT SALES ====================

model AsstMsrt {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  code            String?   @map("Code")
  date            DateTime? @map("Date")
  totalAmt        Decimal?  @map("TotalAmt") @db.Decimal(8, 4)
  discAmt         Decimal?  @map("DiscAmt") @db.Decimal(8, 4)
  netAmt          Decimal?  @map("NetAmt") @db.Decimal(8, 4)
  vatClnNo        String?   @map("VatClnNo")
  vatDate         DateTime? @map("VatDate")
  pricingDate     DateTime? @map("PricingDate")
  type            String?   @map("Type")
  creator         String?   @map("Creator")
  creationDate    DateTime? @map("CreationDate")
  updateBy        String?   @map("UpdateBy")
  updateDate      DateTime? @map("UpdateDate")
  isActive        Boolean?  @map("IsActive")
  customerpay     Decimal?  @map("Customerpay") @db.Decimal(8, 4)
  change          Decimal?  @map("Change") @db.Decimal(8, 4)
  branchId        Int?      @map("BranchId")
  discountRemarks String?   @map("DiscountRemarks")
  details         AsstDet[]

  @@map("AsstMsrt")
}

model AsstDet {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  itemSLNum   String?          @map("ItemSLNum")
  itemOID     String           @map("ItemOID") @db.Uuid
  qty         Decimal?         @map("QTY") @db.Decimal(18, 4)
  uom         String?          @map("UOM")
  price       Decimal?         @map("Price") @db.Decimal(8, 4)
  amount      Decimal?         @map("Amount") @db.Decimal(8, 4)
  sdValue     Decimal?         @map("SDValue") @db.Decimal(8, 4)
  sdAmount    Decimal?         @map("SDAmount") @db.Decimal(8, 4)
  vatValue    Decimal?         @map("VATValue") @db.Decimal(8, 4)
  vatAmount   Decimal?         @map("VATAmount") @db.Decimal(8, 4)
  discount    Decimal?         @map("Discount") @db.Decimal(8, 4)
  netAmount   Decimal?         @map("NetAmount") @db.Decimal(8, 4)
  AsstMsrt_id String?          @map("AsstMsrt_id") @db.Uuid
  item        Item_Information @relation(fields: [itemOID], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sale        AsstMsrt?        @relation(fields: [AsstMsrt_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("AsstDet")
}

// ==================== NC ADJUSTMENT ====================

model t_NCMstr {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @map("NCMstr_OID") @db.Uuid
  ncmstrCode         String?   @map("NCMstr_Code")
  ncmstrDate         DateTime? @map("NCMstr_Date")
  ncmstrCreator      String?   @map("NCMstr_Creator")
  ncmstrCreationDate DateTime? @map("NCMstr_CreationDate")
  ncmstrUpdateBy     String?   @map("NCMstr_UpdateBy")
  ncmstrUpdateDate   DateTime? @map("NCMstr_UpdateDate")
  ncmstrIsActive     Boolean?  @map("NCMstr_IsActive")
  branchId           Int?      @map("BranchId")
  ncmstrName         String?   @map("NCMstr_Name")
  ncmstrContactNo    String?   @map("NCMstr_ContactNo")
  ncmstrReference    String?   @map("NCMstr_Reference")
  details            t_NCDet[]

  @@map("t_NCMstr")
}

model t_NCDet {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @map("NCDet_OID") @db.Uuid
  t_NCMstr_id    String?           @map("NCDet_MStrOID") @db.Uuid
  ncdetItemSLNum String?           @map("NCDet_ItemSLNum")
  ncdetItemOID   String            @map("NCDet_ItemOID") @db.Uuid
